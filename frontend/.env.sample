# Copy this file to .env.local for local development
# .env.local is git-ignored and will NOT be committed

# Backend API URL (leave empty to use the deployed Render backend)
REACT_APP_API_URL=http://localhost:2002/api

# Google Maps API key (optional — only needed for Google Maps features)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
